{
	"name": "detain/tracy-monolog-adapter",
	"type": "library",
	"description": "Bridges the Tracy debugger with the Monolog logger so Tracy log output is routed through Monolog handlers and processors.",
	"keywords": [
		"monolog",
		"tracy",
		"nette",
		"logger",
		"adapter",
		"bridge",
		"psr-3",
		"psr-3-logger",
		"monolog-handler",
		"debug",
		"debug-bar",
		"error-handling",
		"exception",
		"profiling",
		"whoops",
		"php",
		"php-library"
	],
	"homepage": "https://github.com/detain/tracy-monolog-adapter",
	"license": "BSD-3-Clause",
	"authors": [
		{
			"name": "Detain Project",
			"homepage": "https://github.com/detain/tracy-monolog-adapter/graphs/contributors"
		}
	],
	"support": {
		"issues": "https://github.com/detain/tracy-monolog-adapter/issues",
		"source": "https://github.com/detain/tracy-monolog-adapter"
	},
	"require": {
		"php": ">=8.1",
		"tracy/tracy": "^2.10",
		"monolog/monolog": "^3.0"
	},
	"require-dev": {
		"nette/di": "^3.0",
		"phpunit/phpunit": "^9.5 || ^10.0"
	},
	"suggest": {
		"nette/di": "Required for the optional Nette DI bridge in src/Bridges/NetteDI/."
	},
	"autoload": {
		"psr-4": {
			"Detain\\TracyHasMono\\": "src/",
			"Nextras\\TracyMonologAdapter\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\TracyHasMono\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit"
	}
}
